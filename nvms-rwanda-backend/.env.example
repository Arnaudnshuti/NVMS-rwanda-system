# Copy to .env and adjust. PostgreSQL connection string:
# postgresql://USER:PASSWORD@localhost:5432/nvms_rwanda?schema=public
DATABASE_URL=postgresql://postgres:abcd1234@localhost:5432/nvms_rwanda?schema=public
PORT=4000
NODE_ENV=development

# Generate a long random string for production, e.g. openssl rand -hex 32
JWT_SECRET=456b9975b83a4c4bb76782cd5987dfb51ad74b1425c2249439405b8579ac8795

# Comma-separated frontend origins
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Used in invitation/notification emails
SYSTEM_LOGIN_LINK=http://localhost:5173/login

# If SMTP_URL is not set, emails are written to MAIL_OUT_DIR (dev mode).
# SMTP_URL=smtp://user:pass@smtp.example.com:587
MAIL_FROM=nvms@minaloc.gov.rw
MAIL_OUT_DIR=./tmp/emails

# Uploads (dev mode: local disk)
UPLOADS_DIR=./uploads
PUBLIC_BASE_URL=http://localhost:4000
