generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  volunteer
  coordinator
  admin
}

enum VolunteerVerificationStatus {
  pending
  verified
  rejected
}

enum ProfileTrustStatus {
  unsubmitted
  pending_review
  verified
  rejected
}

enum GovStatus {
  active
  suspended
  revoked
}

enum ProgramStatus {
  open
  in_progress
  completed
  draft
}

enum ApplicationStatus {
  submitted
  under_review
  accepted
  waitlisted
  rejected
  withdrawn
}

enum AssignmentStatus {
  active
  completed
  upcoming
}

enum ActivityLogReviewStatus {
  pending
  approved
  rejected
}

model User {
  id                    String                       @id @default(cuid())
  email                 String                       @unique
  passwordHash          String
  name                  String
  role                  UserRole
  isActive              Boolean                      @default(true)
  mustChangePassword    Boolean                      @default(false)
  // Legacy district name (kept for backward compatibility)
  district              String?
  // Canonical district reference
  districtId            String?
  districtRef           District?                    @relation(fields: [districtId], references: [id], onDelete: SetNull)
  phone                 String?
  avatarUrl             String?
  govStatus             GovStatus                    @default(active)
  mfaResetPending       Boolean                      @default(false)
  verificationStatus    VolunteerVerificationStatus?
  profileTrustStatus    ProfileTrustStatus?
  nationalId            String?
  emergencyContactName  String?
  emergencyContactPhone String?
  trustSkillsSummary    String?
  contactPreference     String?
  dateOfBirth           DateTime?
  profession            String?
  educationLevel        String?
  volunteerAvailability String?
  skills                String[]                     @default([])
  hoursContributed      Int                          @default(0)
  programsCompleted     Int                          @default(0)
  rating                Decimal                      @default(0) @db.Decimal(3, 1)

  identityDocuments IdentityDocument[]
  applications      ProgramApplication[] @relation("VolunteerApplications")
  assignments       Assignment[]
  activityLogs      ActivityLog[]
  programsCoordinated Program[]        @relation("ProgramCoordinator")
  auditLogsAsActor   AuditLog[]        @relation("AuditActor")
  auditLogsAsTarget  AuditLog[]        @relation("AuditTarget")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([district])
  @@index([districtId])
  @@index([role])
}

model District {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@index([name])
  @@index([code])
}

model IdentityDocument {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String
  fileName    String
  storageKey  String?
  contentType String?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Program {
  id                   String         @id @default(cuid())
  title                String
  description          String
  category             String
  district             String
  districtId           String?
  districtRef          District?      @relation(fields: [districtId], references: [id], onDelete: SetNull)
  sector               String?
  startDate            DateTime
  endDate              DateTime
  slotsTotal           Int
  slotsFilled          Int            @default(0)
  requiredSkills       String[]       @default([])
  status               ProgramStatus
  coordinatorDisplayName String?
  coordinatorUserId    String?
  coordinatorUser      User?          @relation("ProgramCoordinator", fields: [coordinatorUserId], references: [id])

  applications ProgramApplication[]
  assignments  Assignment[]
  activityLogs ActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([district])
  @@index([districtId])
  @@index([status])
}

model ProgramApplication {
  id               String            @id @default(cuid())
  volunteerId      String
  volunteer        User              @relation("VolunteerApplications", fields: [volunteerId], references: [id], onDelete: Cascade)
  programId        String
  program          Program           @relation(fields: [programId], references: [id], onDelete: Cascade)
  status           ApplicationStatus @default(submitted)
  submittedAt      DateTime          @default(now())
  coordinatorNote  String?
  reviewedAt       DateTime?

  @@index([volunteerId])
  @@index([programId])
  @@index([status])
}

model Assignment {
  id           String           @id @default(cuid())
  volunteerId  String
  volunteer    User             @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  programId    String
  program      Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  programTitle String
  district     String
  startDate    DateTime
  endDate      DateTime
  status       AssignmentStatus
  hoursLogged  Int              @default(0)

  @@index([volunteerId])
}

model ActivityLog {
  id          String                   @id @default(cuid())
  volunteerId String
  volunteer   User                     @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  programId   String
  program     Program                  @relation(fields: [programId], references: [id], onDelete: Cascade)
  date        DateTime
  hours       Decimal                  @db.Decimal(6, 2)
  description String
  status      ActivityLogReviewStatus @default(pending)

  @@index([volunteerId])
}

model PlatformConfig {
  id                  Int    @id @default(1)
  volunteerCategories Json
  programTypes        Json
}

enum AuditActionType {
  AUTH_LOGIN_SUCCESS
  AUTH_LOGIN_FAILURE
  AUTH_PASSWORD_CHANGED
  ADMIN_COORDINATOR_CREATED
  ADMIN_PASSWORD_RESET
  COORDINATOR_VOLUNTEER_APPROVED
  COORDINATOR_VOLUNTEER_REJECTED
  EMAIL_SENT
}

model AuditLog {
  id            String          @id @default(cuid())
  actionType    AuditActionType
  actorUserId   String?
  actorUser     User?           @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  targetUserId  String?
  targetUser    User?           @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  ip            String?
  userAgent     String?
  metadata      Json?
  createdAt     DateTime        @default(now())

  @@index([actionType])
  @@index([actorUserId])
  @@index([targetUserId])
  @@index([createdAt])
}
